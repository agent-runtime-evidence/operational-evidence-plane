{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://operational-evidence-plane.local/schema/bedrock_translation.v0.schema.json",
  "title": "Operational Evidence Plane Bedrock Translation v0",
  "description": "Post-core mapping from OEP evidence artifacts to Amazon Bedrock Agents surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "translation_id",
    "source_checked_at",
    "core_refs",
    "bedrock_runtime_refs",
    "layer_mapping",
    "runtime_mapping",
    "non_goals",
    "source_urls",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "oep.bedrock_translation.v0"},
    "translation_id": {"type": "string", "pattern": "^bedrock_[a-z0-9][a-z0-9_-]*$"},
    "source_checked_at": {"type": "string", "format": "date"},
    "core_refs": {"type": "object"},
    "bedrock_runtime_refs": {"type": "object"},
    "layer_mapping": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["oep_layer", "bedrock_surface", "translation_status", "boundary"],
        "properties": {
          "oep_layer": {"type": "string", "minLength": 1},
          "bedrock_surface": {"type": "string", "minLength": 1},
          "translation_status": {"type": "string", "enum": ["native", "split", "external"]},
          "boundary": {"type": "string", "minLength": 1}
        }
      }
    },
    "runtime_mapping": {"type": "object"},
    "non_goals": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "source_urls": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^https://docs\\.aws\\.amazon\\.com/"}},
    "claim_boundary": {"type": "string", "minLength": 1}
  }
}

