{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://operational-evidence-plane.local/schema/eval_result.v0.schema.json",
  "title": "Operational Evidence Plane Eval Result v0",
  "description": "Deterministic local eval result for an operational trace bundle.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "eval_id",
    "release_manifest_id",
    "trace_id",
    "scenario",
    "status",
    "name",
    "summary",
    "checks",
    "metrics",
    "input_refs",
    "claim_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "oep.eval_result.v0"
    },
    "eval_id": {
      "type": "string",
      "pattern": "^eval_[a-z0-9][a-z0-9_-]*$"
    },
    "release_manifest_id": {
      "type": "string",
      "pattern": "^rmf_[a-z0-9][a-z0-9_-]*$"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "scenario": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["passed", "failed"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/check"}
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_findings",
        "actual_findings",
        "allowed_permission_packets",
        "blocking_evidence_loss_count"
      ],
      "properties": {
        "expected_findings": {"type": "integer", "minimum": 0},
        "actual_findings": {"type": "integer", "minimum": 0},
        "allowed_permission_packets": {"type": "integer", "minimum": 0},
        "blocking_evidence_loss_count": {"type": "integer", "minimum": 0}
      }
    },
    "input_refs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trace_ref",
        "event_ref",
        "permission_packet_ref",
        "fixture_ref",
        "state_ref"
      ],
      "properties": {
        "trace_ref": {"type": "string", "minLength": 1},
        "event_ref": {"type": "string", "minLength": 1},
        "permission_packet_ref": {"type": "string", "minLength": 1},
        "fixture_ref": {"type": "string", "minLength": 1},
        "state_ref": {"type": "string", "minLength": 1}
      }
    },
    "claim_boundary": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "status", "summary"],
      "properties": {
        "check_id": {"type": "string", "minLength": 1},
        "status": {"type": "string", "enum": ["passed", "failed"]},
        "summary": {"type": "string", "minLength": 1}
      }
    }
  }
}

