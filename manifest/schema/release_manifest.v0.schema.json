{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://operational-evidence-plane.local/schema/release_manifest.v0.schema.json",
  "title": "Operational Evidence Plane Release Manifest v0",
  "description": "Scenario-agnostic release-time binding record for reconstructing what model, prompt, tool schema, policy, workflow, rollout, eval, and data-state references were intended to run.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "created_at",
    "release",
    "layer_bindings",
    "runtime_join_rules",
    "rollback",
    "reconstruction",
    "claim_boundaries",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "oep.release_manifest.v0"
    },
    "manifest_id": {
      "type": "string",
      "pattern": "^rmf_[a-z0-9][a-z0-9_-]*$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "release": {
      "$ref": "#/$defs/release_identity"
    },
    "layer_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "prompt",
        "tool_schema",
        "policy",
        "workflow",
        "rollout",
        "eval",
        "data_state"
      ],
      "properties": {
        "model": {
          "allOf": [
            {"$ref": "#/$defs/layer_binding"},
            {"properties": {"layer_type": {"const": "model"}}}
          ]
        },
        "prompt": {
          "allOf": [
            {"$ref": "#/$defs/layer_binding"},
            {"properties": {"layer_type": {"const": "prompt"}}}
          ]
        },
        "tool_schema": {
          "allOf": [
            {"$ref": "#/$defs/layer_binding"},
            {"properties": {"layer_type": {"const": "tool_schema"}}}
          ]
        },
        "policy": {
          "allOf": [
            {"$ref": "#/$defs/layer_binding"},
            {"properties": {"layer_type": {"const": "policy"}}}
          ]
        },
        "workflow": {
          "allOf": [
            {"$ref": "#/$defs/layer_binding"},
            {"properties": {"layer_type": {"const": "workflow"}}}
          ]
        },
        "rollout": {
          "allOf": [
            {"$ref": "#/$defs/layer_binding"},
            {"properties": {"layer_type": {"const": "rollout"}}}
          ]
        },
        "eval": {
          "allOf": [
            {"$ref": "#/$defs/layer_binding"},
            {"properties": {"layer_type": {"const": "eval"}}}
          ]
        },
        "data_state": {
          "allOf": [
            {"$ref": "#/$defs/layer_binding"},
            {"properties": {"layer_type": {"const": "data_state"}}}
          ]
        }
      }
    },
    "runtime_join_rules": {
      "$ref": "#/$defs/runtime_join_rules"
    },
    "rollback": {
      "$ref": "#/$defs/rollback_rules"
    },
    "reconstruction": {
      "$ref": "#/$defs/reconstruction_rules"
    },
    "substitute_context": {
      "type": "array",
      "items": {"$ref": "#/$defs/substitute_context_item"}
    },
    "claim_boundaries": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    }
  },
  "$defs": {
    "release_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "status",
        "environment",
        "scenario",
        "owner",
        "description"
      ],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "status": {
          "type": "string",
          "enum": ["draft", "candidate", "active", "superseded", "rolled_back"]
        },
        "environment": {"type": "string", "minLength": 1},
        "scenario": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "layer_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "layer_type",
        "name",
        "version",
        "binding_status",
        "uri",
        "digest",
        "evidence_role"
      ],
      "properties": {
        "layer_type": {
          "type": "string",
          "enum": [
            "model",
            "prompt",
            "tool_schema",
            "policy",
            "workflow",
            "rollout",
            "eval",
            "data_state"
          ]
        },
        "name": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "binding_status": {
          "type": "string",
          "enum": ["declared", "resolved", "external", "missing"]
        },
        "uri": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "digest": {
          "oneOf": [
            {"type": "null"},
            {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}
          ]
        },
        "evidence_role": {"type": "string", "minLength": 1},
        "notes": {"type": "string"}
      }
    },
    "runtime_join_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "release_manifest_id_field",
        "event_profile_ref",
        "trace_id_field",
        "span_id_field",
        "tool_call_id_field",
        "permission_packet_ref",
        "replay_handle_field"
      ],
      "properties": {
        "release_manifest_id_field": {"type": "string", "minLength": 1},
        "event_profile_ref": {"type": "string", "minLength": 1},
        "trace_id_field": {"type": "string", "minLength": 1},
        "span_id_field": {"type": "string", "minLength": 1},
        "tool_call_id_field": {"type": "string", "minLength": 1},
        "permission_packet_ref": {"type": "string", "minLength": 1},
        "replay_handle_field": {"type": "string", "minLength": 1},
        "notes": {"type": "string"}
      }
    },
    "rollback_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "previous_manifest_id",
        "rollback_candidate_manifest_id_field",
        "required_checks",
        "fail_closed_on_missing"
      ],
      "properties": {
        "previous_manifest_id": {
          "type": ["string", "null"],
          "pattern": "^rmf_[a-z0-9][a-z0-9_-]*$"
        },
        "rollback_candidate_manifest_id_field": {"type": "string", "minLength": 1},
        "required_checks": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "fail_closed_on_missing": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "reconstruction_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ordered_join_steps",
        "minimum_replay_ready_status"
      ],
      "properties": {
        "ordered_join_steps": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/reconstruction_step"}
        },
        "minimum_replay_ready_status": {"type": "string", "minLength": 1}
      }
    },
    "reconstruction_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "evidence_ref", "missing_evidence_result"],
      "properties": {
        "step": {"type": "integer", "minimum": 1},
        "evidence_ref": {"type": "string", "minLength": 1},
        "missing_evidence_result": {"type": "string", "minLength": 1}
      }
    },
    "substitute_context_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "useful_precedent", "boundary"],
      "properties": {
        "surface": {"type": "string", "minLength": 1},
        "useful_precedent": {"type": "string", "minLength": 1},
        "boundary": {"type": "string", "minLength": 1}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_scope",
        "source_artifacts",
        "generated_by",
        "created_from"
      ],
      "properties": {
        "source_scope": {"type": "string", "minLength": 1},
        "source_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "generated_by": {"type": "string", "minLength": 1},
        "created_from": {"type": "string", "minLength": 1}
      }
    }
  }
}

